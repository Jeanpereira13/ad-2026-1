algoritmo "Sal·rio_vendedor"
var

Nome:caractere
SF,TVND,CMV,ST:real

inicio
 escreva("Informe seu nome:")
 leia(Nome)
 escreva("Informe seu sal·rio fixo:")
 leia(SF)
 escreva("Informe o valor total de vendas mensal:")
 leia(TVND)
 CMV <-TVND*15/100
 ST <-SF+CMV

 escreval(Nome)
 escreval("Sal·rio fixo:",SF)
 escreval("Sal·rio total com comiss„o mensal:",ST)

fimalgoritmo